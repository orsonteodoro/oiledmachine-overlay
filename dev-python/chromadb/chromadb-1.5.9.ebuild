# grpcio:>=4 protobuf-python:>=4
gen_grpcio_rdepend_dev() {
	local impl
	for impl in "${PYTHON_COMPAT[@]}" ; do
		echo "
			python_single_target_${impl}? (
				dev-python/grpcio:${PROTOBUF_CPP_SLOT}[python_targets_${impl}(-)]
			)
		"
	done
}

gen_grpcio_bdepend_dev() {
	local impl
	for impl in "${PYTHON_COMPAT[@]}" ; do
		echo "
			(
				python_single_target_${impl}? (
					dev-python/grpcio-tools:${PROTOBUF_CPP_SLOT}[python_targets_${impl}(-)]
					dev-python/protobuf:${PROTOBUF_PYTHON_SLOT}[python_targets_${impl}(-)]
				)
			)
		"
	done
}

gen_grpcio_rdepend_rel() {
	local impl
	for impl in "${PYTHON_COMPAT[@]}" ; do
		echo "
			(
				python_single_target_${impl}? (
					dev-python/grpcio:${PROTOBUF_CPP_SLOT}[python_targets_${impl}(-)]
					dev-python/protobuf:${PROTOBUF_PYTHON_SLOT}[python_targets_${impl}(-)]
				)
			)
		"
	done
}

