 namespace {
 
+// Safe recursive directory scanner that tracks visited absolute paths to block circular references
+void SafeExpandDirectoryRecursive(const ParseNode* function,
+                                 const base::FilePath& current_dir,
+                                 const base::FilePath& base_disk_path,
+                                 const std::string& disk_path_utf8,
+                                 const SourceDir& source_path,
+                                 std::set<base::FilePath>& visited,
+                                 Value& files,
+                                 const std::function<void(const base::FilePath&)>& add_gen_dep) {
+  // Normalize and check for circular filesystem loops (e.g., node21/src -> .)
+  base::FilePath absolute_dir = base::MakeAbsoluteFilePath(current_dir);
+  if (absolute_dir.empty()) absolute_dir = current_dir;
+
+  if (visited.count(absolute_dir) > 0) {
+    return; // File loop detected, escape safely!
+  }
+  visited.insert(absolute_dir);
+
+  // Run FileEnumerator without built-in recursion and without SHOW_SYM_LINKS to isolate traversal
+  base::FileEnumerator traverser(
+      current_dir, false,
+      base::FileEnumerator::FILES | base::FileEnumerator::DIRECTORIES);
+
+  for (base::FilePath current = traverser.Next(); !current.empty(); current = traverser.Next()) {
+    if (traverser.GetInfo().IsDirectory()) {
+      add_gen_dep(current);
+      SafeExpandDirectoryRecursive(function, current, base_disk_path, disk_path_utf8, 
+                                   source_path, visited, files, add_gen_dep);
+    } else {
+      std::string full = source_path.value() +
+                         FilePathToUTF8(current).substr(disk_path_utf8.size());
+      NormalizePath(&full);
+      files.list_value().emplace_back(function, full);
+    }
+  }
+}
