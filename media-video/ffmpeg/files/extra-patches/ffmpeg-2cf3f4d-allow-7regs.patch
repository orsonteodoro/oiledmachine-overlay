# Fix for GCC PGO instrumentation phase when CFLAGS = -O2 -fprofile-generate -fno-reorder-blocks-and-partition
# libswscale/x86/rgb2rgb_template.c:1640:9: error: 'asm' operand has impossible constraints

# If using x86 (32-bit) with PGO set CPPFLAGS=-DALLOW_7REGS=0
# Otherwise, CPPFLAGS=-DALLOW_7REGS=1

diff '--color=auto' -urp ffmpeg-9999.orig/libavcodec/msmpeg4.c ffmpeg-9999/libavcodec/msmpeg4.c
--- ffmpeg-9999.orig/libavcodec/msmpeg4.c	2026-07-22 15:23:09.112544859 -0700
+++ ffmpeg-9999/libavcodec/msmpeg4.c	2026-07-22 15:29:12.137435038 -0700
@@ -228,7 +228,7 @@ int ff_msmpeg4_pred_dc(MpegEncContext *s
        necessitate to modify mpegvideo.c. The problem comes from the
        fact they decided to store the quantized DC (which would lead
        to problems if Q could vary !) */
-#if ARCH_X86 && HAVE_X86_7REGS && HAVE_EBX_AVAILABLE
+#if ARCH_X86 && HAVE_X86_7REGS && ALLOW_7REGS && HAVE_EBX_AVAILABLE
     __asm__ volatile(
         "movl %3, %%eax         \n\t"
         "shrl $1, %%eax         \n\t"
diff '--color=auto' -urp ffmpeg-9999.orig/libavcodec/x86/cabac.h ffmpeg-9999/libavcodec/x86/cabac.h
--- ffmpeg-9999.orig/libavcodec/x86/cabac.h	2026-07-22 15:23:09.352620795 -0700
+++ ffmpeg-9999/libavcodec/x86/cabac.h	2026-07-22 15:29:07.881565161 -0700
@@ -216,7 +216,7 @@
 
 #endif /* BROKEN_RELOCATIONS */
 
-#if HAVE_X86_7REGS && !BROKEN_COMPILER
+#if HAVE_X86_7REGS && ALLOW_7REGS && !BROKEN_COMPILER
 #define get_cabac_inline get_cabac_inline_x86
 static
 #if ARCH_X86_32
diff '--color=auto' -urp ffmpeg-9999.orig/libavcodec/x86/h264_cabac.c ffmpeg-9999/libavcodec/x86/h264_cabac.c
--- ffmpeg-9999.orig/libavcodec/x86/h264_cabac.c	2026-07-22 15:23:09.360537343 -0700
+++ ffmpeg-9999/libavcodec/x86/h264_cabac.c	2026-07-22 15:29:06.009610616 -0700
