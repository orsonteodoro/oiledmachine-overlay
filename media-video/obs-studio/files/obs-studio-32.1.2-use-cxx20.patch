--- obs-studio-32.1.2.orig/frontend/utility/fs-helper.hpp	1969-12-31 16:00:00.000000000 -0800
+++ obs-studio-32.1.2/frontend/utility/fs-helper.hpp	2026-05-10 20:16:47.263808419 -0700
@@ -0,0 +1,15 @@
+#pragma once
+
+#include <filesystem>
+
+// Helper for C++17/C++20 compatibility (u8string() returns std::string in C++17, std::u8string in C++20)
+static inline std::string path_to_string(const std::filesystem::path &p)
+{
+    const auto &u8 = p.u8string();
+    return std::string(u8.begin(), u8.end());
+}
+
+static inline const char *path_to_cstr(const std::filesystem::path &p)
+{
+    return reinterpret_cast<const char*>(p.u8string().c_str());
+}
