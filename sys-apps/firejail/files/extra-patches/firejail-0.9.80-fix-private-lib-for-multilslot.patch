+static lib_class_t get_lib_class(const char *path) {
+        int fd = open(path, O_RDONLY | O_CLOEXEC);
+        if (fd < 0)
+                return LIB_NONE;
+
+        unsigned char e_ident[EI_NIDENT];
+        if (read(fd, e_ident, EI_NIDENT)!= EI_NIDENT) {
+                close(fd);
+                return LIB_NONE;
+        }
+        close(fd);
+
+        if (memcmp(e_ident, ELFMAG, SELFMAG)!= 0)
+                return LIB_NONE;
+
+        if (e_ident[EI_CLASS] == ELFCLASS64)
+                return LIB_64;
+        if (e_ident[EI_CLASS] == ELFCLASS32)
+                return LIB_32;
+        return LIB_NONE;
+}
+
+// Decide which lib dir to use: lib, lib64, lib32, libx32
+static const char *get_dest_libdir(const char *src_path, lib_class_t cls) {
+        // If source path already has lib64/lib32/libx32, respect it
+        if (strstr(src_path, "/lib64/"))
+                return "lib64";
+        if (strstr(src_path, "/lib32/"))
+                return "lib32";
+        if (strstr(src_path, "/libx32/"))
+                return "libx32";
+        if (strstr(src_path, "/lib/"))
+                return "lib";
+
+        // Fallback: use ELF class
+        if (cls == LIB_64)
+                return "lib64";
+        if (cls == LIB_32)
+                return "lib"; // on x86_64, 32-bit usually goes to /lib
+        return "lib";
+}
