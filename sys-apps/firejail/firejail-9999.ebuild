gen_clang_bdepend() {
	local s
	for s in "${LLVM_COMPAT[@]}" ; do
		echo "
		llvm_slot_${s}? (
			llvm-core/clang:${s}
			llvm-core/lld:${s}
			llvm-core/llvm:${s}
			scudo? (
				llvm-runtimes/compiler-rt-sanitizers[scudo]
			)
		)
		"
	done
}

