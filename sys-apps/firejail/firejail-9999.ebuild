		if (( ${retcode} == 0 )) ; then
einfo "${x} passed"
		else
eerror
eerror "Test failed for ${x}.  Return code: ${retcode}.  For details see"
eerror "${T}/test.log"
eerror
			die
		fi
		if grep -q -E -e "Error [0-9]+" "${T}/test.log" ; then
eerror "Test failed for ${x}.  For details see ${T}/test.log"
