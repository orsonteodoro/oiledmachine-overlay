get_supported_commands() {
	local etc_folder="${S}/etc"
	local f
	local L1=(
		$(find "${etc_folder}/"{"profile-a-l","profile-m-z"} -name "*.profile")
	)
	local L2=()
	for f in "${L1[@]}" ; do
		local n=$(basename "${f}" \
			| sed -e "s|\.profile||g")
		L2+=(
			"${n}"
		)
	done
	echo "${L2[@]}" | tr " " $'\n' | sort | uniq
}

is_x_blacklisted() {
	local arg="${1}"
	local y
	for y in "${X_BLACKLIST[@]}" ; do
		if [[ "${arg}" == "${y}" ]] ; then
			return 0
		fi
	done
	return 1
}

