[Unit]
Description=CoolerControl Daemon
After=network.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
Environment="CC_LOG=INFO"
ExecStart=/usr/bin/coolercontrold
Restart=always
RestartSec=1
TimeoutStopSec=10
User=coolercontrold
Group=coolercontrold

[Install]
WantedBy=multi-user.target
