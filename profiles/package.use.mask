# Disabled unreviewed or defuct dependencies for security.
# We want to reduce the attack surface if any.
# They are disabled because of new red team methods, lack of fuzzing evidence, or lacking AI security code review.
# Close these to prevent decades old vulnerability discovery typically by AI or threat actors that use AI.

# The amr repo has not been updated since 2014 without security review so disabled.
media-video/ffmpeg amr

# The repo has not been updated since 2013 without security review so disabled.
media-video/ffmpeg bs2b

# Dependencies are not updated
# libraw1394 repo not updated since 10 years ago
media-video/ffmpeg iec61883

# Dependencies are not updated
# libraw1394 repo not updated since 2016 without a recent security review so disabled.
media-video/ffmpeg ieee1394

# The aribb24 repo has not been updated since 2016 without a recent security review so disabled.
media-video/ffmpeg libaribb24

# The libilbc repo has not been updated since 2021 without a recent security review so disabled.
media-video/ffmpeg libilbc

# The lame ebuild and the lame repo is not up to date on security patches so the mp3 USE flag is disabled.
media-video/ffmpeg lame

# The soxr repo has not been released in 2018 without a recent security review so disabled.
media-video/ffmpeg libsoxr

# The qrencode repo has not been updated since 2020 without a recent security review so disabled.
media-video/ffmpeg qrcode

# EOL project with security issues
media-video/ffmpeg qsv

# The atlas hasn't released since 2016 without a recent security review so disabled
media-libs/opencv atlas

# EOL
net-misc/networkmanager dhclient

# Unmaintained dependency, last release was in 2015
dev-qt/qtimageformats mng

# Unmaintained dependency
media-libs/tiff jbig

# Only vanilla allowed
=sys-kernel/ot-sources-7.2.0.9999 genpatches genpatches_1510 nest rt tresor tresor_prompt tresor_sysfs zen-sauce


