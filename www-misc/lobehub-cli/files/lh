#!/bin/bash

NODE_SLOT=@NODE_SLOT@
# Run lhm as the lobehub user
export HOME="/var/lib/lobehub"
export PATH="/usr/lib/node/${NODE_SLOT}/bin:${PATH}"
export LOBEHUB_SERVER=${LOBEHUB_SERVER:-"http://localhost:3210"}
export LOBEHUB_GATEWAY=${LOBEHUB_GATEWAY:-"ws://localhost:3210/gateway"}
echo "LOBEHUB_SERVER:  ${LOBEHUB_SERVER}"
export LOBEHUB_CLI_HOME=${LOBEHUB_CLI_HOME:-".lobehub"} # Relative to ${HOME}
unset EXTRA_ARGS

cd "/opt/lobehub-cli" || {
    echo "Error: /opt/lobehub-cli directory not found"
    exit 1
}

has_login=0
has_server=0
has_gateway=0
for arg in "${@}"; do
	if [[ "${arg}" == "login" ]] ; then
		has_login=1
	elif [[ "${arg}" == "--server" || "${arg}" == "-s" ]] ; then
		has_server=1
	elif [ "$arg" == "--gateway" ]; then
		has_gateway=1
	fi
done

extra_args=()

# Use fallback defaults
(( ${has_server} == 0 && ${has_login} )) && extra_args+=( "--server" "${LOBEHUB_SERVER}" )
(( ${has_gateway} == 0 )) && extra_args+=( "--gateway" "${LOBEHUB_GATEWAY}" )

cmd=(
	"sudo" "-u" "lobehub" "-g" "lobehub" "--preserve-env=HOME,LOBEHUB_CLI_HOME,LOBEHUB_GATEWAY,LOBEHUB_SERVER,PATH"
	"node" "--no-warnings" "dist/index.js"
	"${@}"
	"${extra_args[@]}"
)

exec "${cmd[@]}"
