#!/bin/bash

ARGS=( "${@}" )

# CWE-653 mitigation with sandbox
LOCAL_AI_FIREJAIL=${LOCAL_AI_FIREJAIL:-@LOCAL_AI_FIREJAIL@}

# Task processing modes:
#                  single - single user, no network (default)
#   federated-worker-node - request processed entirely
# federated-load-balancer - request assigner
#                  worker - requests are split
LOCAL_AI_MODE=${LOCAL_AI_MODE:-"single"}

# Mitigate DoS by FAFO users
# -1000 is never kill process
#     0 is system default
#  <500 is mid-back of the OOM kill list
# >=500 is mid-front of the OOM kill list
#  1000 is front of the line OOM kill
LOCAL_AI_OOM=${LOCAL_AI_OOM:-500}

prepare_backends() {
	if [[ -n "${EXTRA_BACKENDS}" ]] ; then
		local backend
		for backend in ${EXTRA_BACKENDS} ; do
			echo "Preparing backend:  ${backend}"
			make -C "${backend}"
		done
	fi
}

main() {
	[[ -e "/tmp/generated" ]] && echo "[warn] /tmp/generated may need to be manually removed to avoid ownership issue."
	[[ -e "/tmp/localai" ]] && echo "[warn] /tmp/localai may need to be manually removed to avoid ownership issue."

	cd "/opt/local-ai"
	source "/etc/conf.d/local-ai"
	prepare_backends

	local FIREJAIL_ARGS=()
	local LOCAL_AI_ARGS=()

	if [[ -n "${LOCAL_AI_OOM}" ]] ; then
		FIREJAIL_ARGS+=(
			--oom=${LOCAL_AI_OOM}
		)
	fi

	local L=(
		"ANTHROPIC_API_KEY"
		"ANTHROPIC_BASE_URL"
		"BUILD_TYPE"
		"COMPEL"
		"CUDA_VISIBLE_DEVICES"
		"DISABLE_AUTODETECT"
		"EXTRA_BACKENDS"
		"EXTERNAL_GRPC_BACKENDS"
		"FEDERATED_SERVER"
		"GO_TAGS"
		"GALLERIES"
		"GITHUB_CLIENT_ID"
		"GITHUB_CLIENT_SECRET"
		"GPU_TARGETS"
		"HIP_VISIBLE_DEVICES"
		"HTTPS_PROXY"
		"HUGGINGFACE_HUB_CACHE"
		"HUGGINGFACEHUB_API_TOKEN"
		"LD_PRELOAD"
		"LLAMACPP_GRPC_SERVERS"
		"LLAMACPP_PARALLEL"
		"LOCALAI_ADDRESS"
		"LOCALAI_ADMIN_EMAIL"
		"LOCALAI_ADVERTISE_ADDR"
		"LOCALAI_ADVERTISE_HTTP_ADDR"
		"LOCALAI_AGENT_HUB_URL"
		"LOCALAI_AGENT_POOL_API_KEY"
		"LOCALAI_AGENT_POOL_API_URL"
		"LOCALAI_AGENT_POOL_DEFAULT_MODEL"
		"LOCALAI_AGENT_POOL_CHUNK_OVERLAP"
		"LOCALAI_AGENT_POOL_COLLECTION_DB_PATH"
		"LOCALAI_AGENT_POOL_CUSTOM_ACTIONS_DIR"
		"LOCALAI_AGENT_POOL_DATABASE_URL"
		"LOCALAI_AGENT_POOL_EMBEDDING_MODEL"
		"LOCALAI_AGENT_POOL_ENABLE_LOGS"
		"LOCALAI_AGENT_POOL_ENABLE_SKILLS"
		"LOCALAI_AGENT_POOL_MAX_CHUNKING_SIZE"
		"LOCALAI_AGENT_POOL_MULTIMODAL_MODEL"
		"LOCALAI_AGENT_POOL_STATE_DIR"
		"LOCALAI_AGENT_POOL_TRANSCRIPTION_LANGUAGE"
		"LOCALAI_AGENT_POOL_TRANSCRIPTION_MODEL"
		"LOCALAI_AGENT_POOL_TIMEOUT"
		"LOCALAI_AGENT_POOL_TTS_MODEL"
		"LOCALAI_AGENT_POOL_VECTOR_ENGINE"
		"LOCALAI_API_KEY"
		"LOCALAI_ARGS" # Unofficial, ebuild feature
		"LOCALAI_AUTH"
		"LOCALAI_AUTH_DATABASE_URL"
		"LOCALAI_AUTO_APPROVE_NODES"
		"LOCALAI_BACKEND_GALLERIES"
		"LOCALAI_BACKENDS_PATH"
		"LOCALAI_BACKENDS_SYSTEM_PATH"
		"LOCALAI_BASE_URL"
		"LOCALAI_CONFIG_DIR"
		"LOCALAI_CONTEXT_SIZE"
		"LOCALAI_CORS"
		"LOCALAI_CORS_ALLOW_ORIGINS"
		"LOCALAI_DISABLE_AGENTS"
		"LOCALAI_DISABLE_ASSISTANT"
		"LOCALAI_DISABLE_LOCAL_AUTH"
		"LOCALAI_DISABLE_MCP"
		"LOCALAI_DISTRIBUTED"
		"LOCALAI_EXPOSE_NODE_HEADER"
		"LOCALAI_EXTERNAL_BACKENDS"
		"LOCALAI_EXTERNAL_GRPC_BACKENDS"
		"LOCALAI_F16"
		"LOCALAI_FEDERATED"
		"LOCALAI_FORCE_BACKEND_SHUTDOWN"
		"LOCALAI_FORCE_EVICTION_WHEN_BUSY"
		"LOCALAI_FORCE_META_BACKEND_CAPABILITY"
		"LOCALAI_GALLERIES"
		"LOCALAI_GENERATED_CONTENT_PATH"
		"LOCALAI_HEARTBEAT_INTERVAL"
		"LOCALAI_HTTP_ADDR"
		"LOCALAI_INSTANCE_ID"
		"LOCALAI_LOG_LEVEL"
		"LOCALAI_LRU_EVICTION_MAX_RETRIES"
		"LOCALAI_LRU_EVICTION_RETRY_INTERVAL"
		"LOCALAI_MAX_ACTIVE_BACKENDS"
		"LOCALAI_MITM_CA_DIR"
		"LOCALAI_MITM_INTERCEPT_HOSTS"
		"LOCALAI_MITM_LISTEN"
		"LOCALAI_MODELS_CONFIG_FILE"
		"LOCALAI_MODELS_PATH"
		"LOCALAI_NATS_BACKEND_INSTALL_TIMEOUT"
		"LOCALAI_NATS_BACKEND_UPGRADE_TIMEOUT"
		"LOCALAI_NATS_URL"
		"LOCALAI_NODE_LABELS"
		"LOCALAI_NODE_NAME"
		"LOCALAI_OIDC_CLIENT_ID"
		"LOCALAI_OIDC_CLIENT_SECRET"
		"LOCALAI_OIDC_ISSUER"
		"LOCALAI_P2P"
		"LOCALAI_P2P_BOOTSTRAP_PEERS_MADDRS"
		"LOCALAI_P2P_DHT_ANNOUNCE_MADDRS"
		"LOCALAI_P2P_DISABLE_DHT"
		"LOCALAI_P2P_ENABLE_LIMITS"
		"LOCALAI_P2P_LIB_LOGLEVEL"
		"LOCALAI_P2P_LISTEN_MADDRS"
		"LOCALAI_P2P_LOGLEVEL"
		"LOCALAI_P2P_TOKEN"
		"LOCALAI_PARALLEL_REQUESTS"
		"LOCALAI_REGISTER_TO"
		"LOCALAI_REGISTRATION_MODE"
		"LOCALAI_REGISTRATION_TOKEN"
		"LOCALAI_SERVE_ADDR"
		"LOCALAI_SINGLE_ACTIVE_BACKEND"
		"LOCALAI_STORAGE_ACCESS_KEY"
		"LOCALAI_STORAGE_BUCKET"
		"LOCALAI_STORAGE_REGION"
		"LOCALAI_STORAGE_SECRET_KEY"
		"LOCALAI_STORAGE_URL"
		"LOCALAI_THREADS"
		"LOCALAI_UPLOAD_LIMIT"
		"LOCALAI_WATCHDOG_BUSY"
		"LOCALAI_WATCHDOG_BUSY_TIMEOUT"
		"LOCALAI_WATCHDOG_IDLE"
		"LOCALAI_WATCHDOG_IDLE_TIMEOUT"
		"MAX_ACTIVE_BACKENDS"
		"MLX_DISTRIBUTED_BACKEND"
		"MLX_DISTRIBUTED_HOSTFILE"
		"MODELS_PATH"
		"NODE_EXTRA_CA_CERTS"
		"NVIDIA_DRIVER_CAPABILITIES"
		"OPENAI_API_KEY"
		"PARALLEL_REQUEST"
		"PRELOAD_MODELS"
		"PRELOAD_MODELS_CONFIG"
		"PYTHON_GRPC_MAX_WORKERS"
		"REBUILD"
		"TOKEN"
	)

	local x
	for x in "${L[@]}" ; do
		[[ "${x}" == "LOCALAI_ARGS" ]] && continue
		if [[ -n "${!x}" ]] ; then
			FIREJAIL_ARGS+=(
				--env=${x}="${!x}"
			)
			export ${x}
		fi
	done

	if [[ "${LOCAL_AI_MODE}" == "federated-worker-node" ]] ; then
		LOCAL_AI_ARGS+=(
			"run" "--p2p" "--federated"
		)
	elif [[ "${LOCAL_AI_MODE}" == "federated-load-balancer" ]] ; then
		LOCAL_AI_ARGS+=(
			"federated"
		)
	elif [[ "${LOCAL_AI_MODE}" == "worker" ]] ; then
		LOCAL_AI_ARGS+=(
			"run" "--p2p"
		)
	else
	# Single
		LOCAL_AI_ARGS+=(
			"run"
		)
	fi

	LOCAL_AI_ARGS+=(
		${LOCALAI_ARGS}
	)

	if [[ "${LOCAL_AI_FIREJAIL}" == "1" ]] ; then
		"/usr/bin/firejail" --profile="local-ai" ${FIREJAIL_ARGS[@]} "/opt/local-ai/local-ai" ${LOCAL_AI_ARGS[@]} "${ARGS[@]}"
	else
		"/opt/local-ai/local-ai" "${ARGS[@]}"
	fi
}

main
