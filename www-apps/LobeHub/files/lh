#!/bin/bash

NODE_SLOT=@NODE_SLOT@
# Run lhm as the lobehub user
export AGENT_GATEWAY_URL=${AGENT_GATEWAY_URL:-"@AGENT_GATEWAY_URL@"}		# Official var name
export DEVICE_GATEWAY_URL=${DEVICE_GATEWAY_URL:-"@DEVICE_GATEWAY_URL@"}		# Wrapper var name
export HOME="/var/lib/lobehub"
export LOBEHUB_CLI_HOME=${LOBEHUB_CLI_HOME:-".lobehub"}				# Official var name, value relative to ${HOME}
export LOBEHUB_SERVER=${LOBEHUB_SERVER:-"@LOBEHUB_SERVER@"}			# Official var name
export PATH="/usr/lib/node/${NODE_SLOT}/bin:${PATH}"

cd "/opt/lobehub-cli" || {
    echo "Error: /opt/lobehub-cli directory not found"
    exit 1
}

command=""
[[ "${1}" == "connect" ]] && command="connect"
[[ "${1}" == "login" ]] && command="login"
[[ "${1}" == "status" ]] && command="status"

has_server=0
has_gateway=0

for arg in "${@}"; do
	if [[ "${arg}" == "--server" || "${arg}" == "-s" ]] ; then
		has_server=1
	elif [ "$arg" == "--gateway" ]; then
		has_gateway=1
	fi
done

extra_args=()

# Use fallback defaults
(( ${has_server} == 0 )) && [[ "${command}" == "login" ]] && extra_args+=( "--server" "${LOBEHUB_SERVER}" )
(( ${has_gateway} == 0 )) && [[ "${command}" =~ ("status"|"connect") ]] && extra_args+=( "--gateway" "${DEVICE_GATEWAY_URL}" )

cmd=(
	"sudo" "-u" "lobehub" "-g" "lobehub" "--preserve-env=AGENT_GATEWAY_URL,HOME,LOBEHUB_CLI_HOME,LOBEHUB_SERVER,PATH"
	"node" "--no-warnings" "dist/index.js"
	"${@}"
	"${extra_args[@]}"
)

exec "${cmd[@]}"
