+    const client = postgres(connectionString, {
+      max: 20,              // The connection pool size.  Increase it to support many users.
+      idle_timeout: 30,
+      connect_timeout: 10,
+      prepare: false,       // helps with PG17 + Drizzle stability
+    });
+    return postgresJsDrizzle(client, { schema });
