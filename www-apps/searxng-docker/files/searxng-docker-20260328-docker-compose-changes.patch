diff '--color=auto' -urp searxng-docker-9999.orig/container/docker-compose.yml searxng-docker-9999/container/docker-compose.yml
--- searxng-docker-9999.orig/container/docker-compose.yml	2026-04-06 04:47:43.534683420 -0700
+++ searxng-docker-9999/container/docker-compose.yml	2026-04-06 04:59:39.613186282 -0700
@@ -7,7 +7,9 @@ services:
   core:
     container_name: searxng-core
     image: docker.io/searxng/searxng:${SEARXNG_VERSION:-latest}
-    restart: always
+    # Security improvements
+    user: "@SEARXNG_CORE_UID@:@SEARXNG_CORE_GID@"      # Run as searxng:searxng (non-root)
+    restart: unless-stopped
     ports:
       - ${SEARXNG_HOST:+${SEARXNG_HOST}:}${SEARXNG_PORT:-8080}:${SEARXNG_PORT:-8080}
     env_file: ./.env
@@ -15,14 +17,37 @@ services:
       - ./core-config/:/etc/searxng/:Z
       - core-data:/var/cache/searxng/
 
+    # Hardening
+    cap_drop:
+      - ALL
+    cap_add:
+      - CHOWN
+      - SETGID
+      - SETUID
+      - DAC_OVERRIDE
+    security_opt:
+      - no-new-privileges:true
+    read_only: false                                   # Required for writing to /etc/searxng
+    tmpfs:
+      - /tmp:noexec,size=64M
+
   valkey:
     container_name: searxng-valkey
     image: docker.io/valkey/valkey:9-alpine
     command: valkey-server --save 30 1 --loglevel warning
-    restart: always
+    restart: unless-stopped
+    user: "@VALKEY_UID@:@VALKEY_GID@"                  # Run as searxng-valkey:searxng-valkey (non-root)
     volumes:
       - valkey-data:/data/
 
+    # Hardening for valkey
+    cap_drop:
+      - ALL
+    security_opt:
+      - no-new-privileges:true
+    tmpfs:
+      - /tmp:noexec,size=32M
+
 volumes:
   core-data:
   valkey-data:
