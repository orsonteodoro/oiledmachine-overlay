+void RiceBackend::setSocketTypeOfService(unsigned streamId, unsigned value)
+{
+#if RICE_CHECK_VERSION(0, 2, 2)
+    auto sockets = getSocketsForStream(streamId);
+    if (!sockets) [[unlikely]]
+        return;
+
+    rice_sockets_set_tos(sockets.get(), value);
+#else
+    UNUSED_PARAM(streamId);
+    UNUSED_PARAM(value);
+#endif
+}
