 WebCore::RiceGatherResult webkitGstWebRTCIceAgentGatherSocketAddresses(WebKitGstIceAgent*, unsigned);
 
diff --git a/Source/WebCore/Modules/mediastream/gstreamer/GStreamerIceStream.cpp b/Source/WebCore/Modules/mediastream/gstreamer/GStreamerIceStream.cpp
index b410e894e074..ae5cd9e7cf06 100644
