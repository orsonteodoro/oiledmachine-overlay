{
  "packageManager": "pnpm@10.18.1",
  "name": "signal-art-creator",
  "private": true,
  "version": "0.0.0",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Signal Messenger, LLC",
    "email": "support@signal.org"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:protos && tsc && vite build --base=./",
    "check:types": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "run-p eslint prettier:format",
    "eslint": "eslint --cache .",
    "prettier:format": "prettier --list-different --cache --write .",
    "prettier:check": "prettier --cache --check .",
    "build:protos": "protopiler --output src/util/protos.js --typedefs src/util/protos.d.ts ./protos"
  },
  "dependencies": {
    "@babel/helpers": "7.26.10",
    "@babel/runtime": "7.26.10",
    "@indutny/emoji-picker-react": "4.10.1",
    "@indutny/protopiler": "4.0.0",
    "@popperjs/core": "2.11.8",
    "@react-aria/interactions": "3.19.0",
    "@reduxjs/toolkit": "1.9.5",
    "@remix-run/router": "1.23.2",
    "ajv": "8.18.0",
    "base64-js": "1.5.1",
    "classnames": "2.3.2",
    "debug": "4.3.4",
    "js-yaml": "4.1.1",
    "lodash": "4.18.0",
    "markdown-it": "14.1.1",
    "minimatch": "10.2.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "14.2.3",
    "react-intl": "6.4.1",
    "react-popper": "2.3.0",
    "react-redux": "8.0.5",
    "react-router": "6.30.2",
    "react-router-dom": "6.10.0",
    "react-sortablejs": "6.1.4",
    "redux": "4.2.1",
    "reselect": "4.1.8",
    "sortablejs": "1.15.0",
    "tmp": "0.2.4",
    "underscore": "1.13.8"
  },
  "devDependencies": {
    "@types/debug": "4.1.7",
    "@types/react": "18.3.20",
    "@types/react-dom": "18.3.6",
    "@types/sortablejs": "1.15.1",
    "@typescript-eslint/eslint-plugin": "5.59.0",
    "@typescript-eslint/parser": "5.59.0",
    "@vitejs/plugin-react": "3.1.0",
    "cross-spawn": "6.0.6",
    "esbuild": "0.25.9",
    "eslint": "8.38.0",
    "eslint-config-airbnb-typescript-prettier": "5.0.0",
    "eslint-plugin-react": "7.32.2",
    "flatted": "3.4.2",
    "happy-dom": "20.8.9",
    "immutable": "5.1.5",
    "npm-run-all2": "8.0.4",
    "picomatch": "4.0.4",
    "prettier": "2.8.7",
    "rollup": "3.30.0",
    "rollup-plugin-visualizer": "5.9.0",
    "sass": "1.62.0",
    "typescript": "5.0.4",
    "vite": "6.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ],
    "ignoredBuiltDependencies": [
      "es5-ext"
    ]
  }
}
