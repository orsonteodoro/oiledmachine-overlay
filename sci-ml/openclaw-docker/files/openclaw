#!/bin/sh
# Gentoo-friendly wrapper for OpenClaw
# Automatically uses pre-built image to avoid Bun build issues

export OPENCLAW_IMAGE="${OPENCLAW_IMAGE:-ghcr.io/openclaw/openclaw:@OPENCLAW_TAG@}"

# Force correct paths BEFORE docker-setup.sh can overwrite them
export OPENCLAW_CONFIG_DIR="/home/node/.openclaw"
export OPENCLAW_WORKSPACE_DIR="/home/node/.openclaw/workspace"

# Auto-detect Docker GID on Gentoo
if [ -S /var/run/docker.sock ]; then
    DOCKER_GID=$(stat -c '%g' /var/run/docker.sock 2>/dev/null || echo "48")
    export DOCKER_GID
else
    DOCKER_GID=48
    export DOCKER_GID
fi

# Optional: You can still override with a different tag/image
# Example: OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:main openclaw

cd "/opt/openclaw" || {
    echo "Error: /opt/openclaw directory not found" >&2
    exit 1
}

# Fix .env before running setup (in case it already exists)
if [[ -f .env ]]; then
    sed -i \
        -e 's|^OPENCLAW_CONFIG_DIR=.*|OPENCLAW_CONFIG_DIR=/home/node/.openclaw|' \
        -e 's|^OPENCLAW_WORKSPACE_DIR=.*|OPENCLAW_WORKSPACE_DIR=/home/node/.openclaw/workspace|' \
        .env
fi

OPENCLAW_UID=$(id -u "openclaw")
OPENCLAW_GID=$(id -g "openclaw")

# Pre-create .env with correct values so setup.sh respects them
sed -i \
	-e "/OPENCLAW_CONFIG_DIR/d" \
	-e "/OPENCLAW_WORKSPACE_DIR/d" \
	-e "/DOCKER_GID/d" \
	-e "/DOCKER_SOCKET_PATH/d" \
	".env"
cat >> ".env" <<EOF
OPENCLAW_CONFIG_DIR=/home/node/.openclaw
OPENCLAW_WORKSPACE_DIR=/home/node/.openclaw/workspace
DOCKER_GID=${DOCKER_GID}
DOCKER_SOCKET_PATH=/var/run/docker.sock
EOF

# Create override to survive setup.sh
cat > "docker-compose.override.yml" <<EOL
services:
  openclaw-gateway:
    user: "@OPENCLAW_UID@:@OPENCLAW_GID@"
    volumes:
      - /var/lib/openclaw:/home/node/.openclaw
      - /var/run/docker.sock:/var/run/docker.sock:ro
    group_add:
      - "@DOCKER_GID@"
EOL

echo "==> Using OpenClaw image: ${OPENCLAW_IMAGE} (running as UID/GID ${OPENCLAW_UID}:${OPENCLAW_GID})"
exec "./docker-setup.sh" "$@"
