diff '--color=auto' -urp gmp-6.3.0.orig/mini-gmp/mini-gmp.c gmp-6.3.0/mini-gmp/mini-gmp.c
--- gmp-6.3.0.orig/mini-gmp/mini-gmp.c	2023-07-29 06:42:16.000000000 -0700
+++ gmp-6.3.0/mini-gmp/mini-gmp.c	2026-06-27 10:09:44.517949770 -0700
